#!/usr/bin/env node
process.chdir(__dirname);

const childProcess = require("child_process");
childProcess.execSync("depsync");

process.argv.push("../");
process.argv.push("-w");
process.argv.push("-DTGFX_BUILD_HELLO2D=ON")
let args = process.argv.slice(2);
if (args.indexOf("-p") === -1 && args.indexOf("--platform") === -1) {
    process.argv.push("-p");
    process.argv.push("mac");
}
require("../third_party/vendor_tools/xcode-gen");

const fs = require("fs");
const path = require("path");
const useMetal = process.argv.some(arg => arg === "-DTGFX_USE_METAL=ON");
const pbxprojPath = path.join(__dirname, "Hello2D.xcodeproj/project.pbxproj");
let pbxproj = fs.readFileSync(pbxprojPath, "utf8");
// Remove any existing TGFX_USE_METAL entries first.
pbxproj = pbxproj.replace(/\s*TGFX_USE_METAL,?\n?/g, "");
pbxproj = pbxproj.replace(/\s*TGFX_USE_METAL;?\n?/g, "");
if (useMetal) {
    // Inject TGFX_USE_METAL into target-level GCC_PREPROCESSOR_DEFINITIONS (identified by
    // containing GL_SILENCE_DEPRECATION). Handles both array and single-value formats.
    pbxproj = pbxproj.replace(
        /GCC_PREPROCESSOR_DEFINITIONS = \(\s*\n([\s\S]*?GL_SILENCE_DEPRECATION[\s\S]*?)\);/g,
        function (match, inner) {
            let trimmed = inner.trimEnd();
            if (!trimmed.endsWith(",")) {
                trimmed += ",";
            }
            return "GCC_PREPROCESSOR_DEFINITIONS = (\n" + trimmed + "\n\t\t\t\t\tTGFX_USE_METAL,\n\t\t\t\t);";
        }
    );
    pbxproj = pbxproj.replace(
        /GCC_PREPROCESSOR_DEFINITIONS = (GL_SILENCE_DEPRECATION);/g,
        "GCC_PREPROCESSOR_DEFINITIONS = (\n\t\t\t\t\t$1,\n\t\t\t\t\tTGFX_USE_METAL,\n\t\t\t\t);"
    );
}
fs.writeFileSync(pbxprojPath, pbxproj);
